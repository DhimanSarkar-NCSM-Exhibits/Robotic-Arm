// --- Kinematics and Representation ---

@article{Denavit1955,
  author  = {Jacques Denavit and Richard S. Hartenberg},
  title   = {A Kinematic Notation for Lower-Pair Mechanisms Based on Matrices},
  journal = {Journal of Applied Mechanics},
  year    = {1955},
  volume  = {22},
  pages   = {215--221},
  note    = {The original paper introducing the Denavit-Hartenberg (DH) convention — the universal standard for describing robot kinematics.}
}

@article{Shoemake1985,
  author    = {Ken Shoemake},
  title     = {Animating Rotation with Quaternion Curves},
  booktitle = {Proceedings of SIGGRAPH},
  year      = {1985},
  pages     = {245--254},
  doi       = {10.1145/325334.325242},
  note      = {Foundational paper on quaternion interpolation (SLERP) — the standard method for smooth rotation representation in robotics and animation.}
}

@article{Pieper1968,
  author  = {Donald L. Pieper},
  title   = {The Kinematics of Manipulators Under Computer Control},
  school  = {Stanford University},
  year    = {1968},
  note    = {Stanford PhD thesis. Proved the closed-form inverse kinematics condition for six-DOF arms with three consecutive revolute joint axes intersecting at a point — the basis of most industrial robot wrist designs.}
}

// --- Inverse Kinematics ---

@article{Whitney1969,
  author  = {Daniel E. Whitney},
  title   = {Resolved Motion Rate Control of Manipulators and Human Prostheses},
  journal = {IEEE Transactions on Man-Machine Systems},
  year    = {1969},
  volume  = {10},
  number  = {2},
  pages   = {47--53},
  doi     = {10.1109/TMMS.1969.299896},
  note    = {Introduced the Jacobian pseudoinverse method for resolved-rate control — foundational to velocity-level inverse kinematics.}
}

@article{Nakamura1986,
  author  = {Yoshihiko Nakamura and Hideo Hanafusa},
  title   = {Inverse Kinematic Solutions with Singularity Robustness for Robot Manipulator Control},
  journal = {Journal of Dynamic Systems, Measurement, and Control},
  year    = {1986},
  volume  = {108},
  number  = {3},
  pages   = {163--171},
  doi     = {10.1115/1.3143764},
  note    = {Introduced the damped least squares (DLS) method for handling kinematic singularities — widely used in real robot controllers.}
}

@article{Wampler1986,
  author  = {Charles W. Wampler},
  title   = {Manipulator Inverse Kinematic Solutions Based on Vector Formulations and Damped Least-Squares Methods},
  journal = {IEEE Transactions on Systems, Man, and Cybernetics},
  year    = {1986},
  volume  = {16},
  number  = {1},
  pages   = {93--101},
  doi     = {10.1109/TSMC.1986.289283}
}

@article{Buss2004,
  author  = {Samuel R. Buss},
  title   = {Introduction to Inverse Kinematics with Jacobian Transpose, Pseudoinverse and Damped Least Squares Methods},
  journal = {IEEE Transactions on Robotics and Automation},
  year    = {2004},
  note    = {Widely circulated tutorial paper covering the major numerical inverse kinematics methods. Freely available online.}
}

