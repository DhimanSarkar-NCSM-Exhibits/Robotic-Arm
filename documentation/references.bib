// -------------------------------------------------------
// Historical Development of Robotics
// -------------------------------------------------------

@article{Denavit1955,
  author  = {Jacques Denavit and Richard S. Hartenberg},
  title   = {A Kinematic Notation for Lower-Pair Mechanisms Based on Matrices},
  journal = {Journal of Applied Mechanics},
  year    = {1955},
  volume  = {22},
  pages   = {215--221},
  note    = {The paper that started it all. Introduced the Denavit-Hartenberg (DH) convention — the universal notation for describing robot joint frames and link geometry. Every robotic arm kinematic model in existence uses this framework.}
}

@article{Engelberger1980,
  author    = {Joseph F. Engelberger},
  title     = {Robotics in Practice: Management and Applications of Industrial Robots},
  year      = {1980},
  publisher = {AMACOM},
  isbn      = {978-0-814-45356-0},
  note      = {Written by the Father of Industrial Robotics, who commercialised the first industrial robot arm (Unimate) in the early 1960s. A first-hand account of the birth of the robotics industry.}
}

@article{Whitney1969,
  author  = {Daniel E. Whitney},
  title   = {Resolved Motion Rate Control of Manipulators and Human Prostheses},
  journal = {IEEE Transactions on Man-Machine Systems},
  year    = {1969},
  volume  = {10},
  number  = {2},
  pages   = {47--53},
  doi     = {10.1109/TMMS.1969.299896},
  note    = {MIT. Introduced the Jacobian pseudoinverse method for robot velocity control — one of the most consequential single ideas in the history of robot control, still used in every modern robot controller.}
}

@article{Luh1980,
  author  = {J. Y. S. Luh and M. W. Walker and R. P. C. Paul},
  title   = {On-Line Computational Scheme for Mechanical Manipulators},
  journal = {Journal of Dynamic Systems, Measurement, and Control},
  year    = {1980},
  volume  = {102},
  number  = {2},
  pages   = {69--76},
  doi     = {10.1115/1.3149599},
  note    = {Purdue University. Introduced the recursive Newton-Euler algorithm for computing robot dynamics in real time. Made real-time robot control computationally feasible for the first time, enabling the explosion of industrial robotics in the 1980s.}
}

@article{Arimoto1984,
  author  = {Suguru Arimoto and Sadao Kawamura and Fumio Miyazaki},
  title   = {Bettering Operation of Robots by Learning},
  journal = {Journal of Robotic Systems},
  year    = {1984},
  volume  = {1},
  number  = {2},
  pages   = {123--140},
  doi     = {10.1002/rob.4620010203},
  note    = {Osaka University. Introduced Iterative Learning Control (ILC) — the concept that a robot can systematically improve its motion accuracy over repeated trials. A landmark in the history of robot learning, predating modern machine learning by decades.}
}


// -------------------------------------------------------
// Notable Contributions by Research Groups
// -------------------------------------------------------

@article{Khatib1987,
  author  = {Oussama Khatib},
  title   = {A Unified Approach for Motion and Force Control of Robot Manipulators: The Operational Space Formulation},
  journal = {IEEE Journal on Robotics and Automation},
  year    = {1987},
  volume  = {3},
  number  = {1},
  pages   = {43--53},
  doi     = {10.1109/JRA.1987.1087068},
  note    = {Stanford Robotics Lab. Introduced operational space control — the framework that allows a robot to be controlled directly in task space (position and force at the end-effector) rather than joint space. Foundational to modern force-controlled and collaborative robots.}
}

@article{Hogan1985,
  author  = {Neville Hogan},
  title   = {Impedance Control: An Approach to Manipulation},
  journal = {Journal of Dynamic Systems, Measurement, and Control},
  year    = {1985},
  volume  = {107},
  number  = {1},
  pages   = {1--24},
  doi     = {10.1115/1.3140706},
  note    = {MIT. Introduced impedance control — the idea of controlling the dynamic relationship between force and motion rather than specifying either alone. The theoretical basis of every compliant and safe robot that physically interacts with humans or uncertain environments.}
}

@article{Yoshikawa1990ref,
  author  = {Tsuneo Yoshikawa},
  title   = {Manipulability of Robotic Mechanisms},
  journal = {International Journal of Robotics Research},
  year    = {1985},
  volume  = {4},
  number  = {2},
  pages   = {3--9},
  doi     = {10.1177/027836498500400201},
  note    = {University of Tokyo. Introduced the manipulability ellipsoid and manipulability measure — the standard tools for quantifying how well a robot arm can move and exert force in different configurations. Used universally in robot design and motion optimisation.}
}

@article{Hirose1993ref,
  author  = {Shigeo Hirose and Yoji Umetani},
  title   = {The Development of Soft Gripper for the Versatile Robot Hand},
  journal = {Mechanism and Machine Theory},
  year    = {1978},
  volume  = {13},
  number  = {3},
  pages   = {351--359},
  doi     = {10.1016/0094-114X(78)90059-9},
  note    = {Tokyo Institute of Technology. Hirose's group pioneered biologically inspired robot design. This paper introduced the soft gripper concept — adaptable end-effectors that conform to object shape without complex sensing, influencing decades of robot hand design worldwide.}
}

@article{Levine2016,
  author  = {Sergey Levine and Chelsea Finn and Trevor Darrell and Pieter Abbeel},
  title   = {End-to-End Training of Deep Visuomotor Policies},
  journal = {Journal of Machine Learning Research},
  year    = {2016},
  volume  = {17},
  pages   = {1--40},
  url     = {https://arxiv.org/abs/1504.00702},
  note    = {UC Berkeley. Demonstrated that a robot arm can learn complex manipulation tasks — including object grasping — directly from raw camera images, with no hand-crafted features or intermediate representations. A defining moment in the application of deep learning to physical robots.}
}


// -------------------------------------------------------
// State-of-the-Art Research Problems
// -------------------------------------------------------

@article{Rus2015,
  author  = {Daniela Rus and Michael T. Tolley},
  title   = {Design, Fabrication and Control of Soft Robots},
  journal = {Nature},
  year    = {2015},
  volume  = {521},
  pages   = {467--475},
  doi     = {10.1038/nature14543},
  url     = {https://www.nature.com/articles/nature14543},
  note    = {MIT CSAIL and UCSD. Defines the field of soft robotics — robots built from compliant, deformable materials inspired by biological organisms. Soft robots can safely interact with humans, navigate unstructured environments, and handle delicate objects in ways rigid robots cannot. An active frontier of robotics research.}
}

@article{Haddadin2009,
  author  = {Sami Haddadin and Alin Albu-Schaffer and Gerd Hirzinger},
  title   = {Requirements for Safe Robots: Measurements, Analysis and New Insights},
  journal = {International Journal of Robotics Research},
  year    = {2009},
  volume  = {28},
  number  = {11--12},
  pages   = {1507--1527},
  doi     = {10.1177/0278364909343970},
  note    = {German Aerospace Center (DLR). Established the quantitative physical safety requirements for robots working alongside humans. This work directly enabled the development of collaborative robots (cobots) and underpins the ISO safety standards governing human-robot interaction in industry today.}
}

@article{Mnih2015,
  author  = {Volodymyr Mnih and Koray Kavukcuoglu and David Silver and others},
  title   = {Human-Level Control Through Deep Reinforcement Learning},
  journal = {Nature},
  year    = {2015},
  volume  = {518},
  pages   = {529--533},
  doi     = {10.1038/nature14236},
  url     = {https://www.nature.com/articles/nature14236},
  note    = {DeepMind. Introduced Deep Q-Networks (DQN) — the paper that launched the modern era of deep reinforcement learning. Though demonstrated on games, the same framework is now central to training robot locomotion, manipulation, and autonomous navigation policies, and represents one of the most active research directions in robotics today.}
}

@article{Openai2019,
  author  = {OpenAI and Marcin Andrychowicz and Bowen Baker and others},
  title   = {Dexterous In-Hand Manipulation},
  journal = {International Journal of Robotics Research},
  year    = {2020},
  volume  = {39},
  number  = {1},
  pages   = {3--20},
  doi     = {10.1177/0278364919887447},
  url     = {https://arxiv.org/abs/1808.00177},
  note    = {OpenAI. Trained a robotic hand to solve a Rubik's cube using reinforcement learning entirely in simulation, then transferred the policy to a real physical hand. A landmark result in sim-to-real transfer and dexterous manipulation — two of the hardest open problems in robotics.}
}

@article{Peng2021,
  author  = {Xue Bin Peng and Erwin Coumans and Tingnan Zhang and Tsang-Wei Lee and Jie Tan and Sergey Levine},
  title   = {Learning Agile Robotic Locomotion Skills by Imitating Animals},
  journal = {Robotics: Science and Systems},
  year    = {2020},
  doi     = {10.15607/RSS.2020.XVI.064},
  url     = {https://arxiv.org/abs/2004.00784},
  note    = {UC Berkeley and Google Brain. Demonstrated that four-legged robots can learn highly agile, natural-looking movements — backflips, sprinting, sharp turns — by imitating motion-captured animal locomotion data using deep reinforcement learning. Represents the state of the art in legged robot mobility.}
}